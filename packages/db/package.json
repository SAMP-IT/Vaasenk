{
  "name": "@vaasenk/db",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, and database client for Vaasenk (Supabase Postgres + pgvector).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "exit 0",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:format": "prisma format --schema=./prisma/schema.prisma",
    "db:validate": "prisma validate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:seed": "prisma db seed --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.47.10",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "ws": "^8.18.0"
  }
}
