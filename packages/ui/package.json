{
  "name": "@vaasenk/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Vaasenk design tokens, theme files, and base UI primitives shared between web and mobile.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./tokens/index.ts",
    "./tokens/json": "./tokens/vaasenk.tokens.json",
    "./tokens/css": "./tokens/theme.css",
    "./tokens/tailwind": "./tokens/tailwind.theme.css",
    "./tokens/native": "./tokens/native-theme.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "exit 0",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
