# Vaasenk — Docker build context exclusions.
#
# Build context is the monorepo root (Railway sets it this way). Keep the
# image lean by skipping anything not needed for build/runtime.

# Dependencies
**/node_modules

# Build outputs
**/dist
**/build
**/.next
**/.turbo
**/*.tsbuildinfo

# VCS + tooling
.git
.gitignore
.github

# Logs + local state
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Environment files (secrets must come from runtime env, not the image)
**/.env
**/.env.*
!**/.env.example

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Docs / design assets (not needed at runtime)
docs
design-docs
**/*.md
!**/README.md

# Test artifacts
**/coverage
**/.nyc_output

# Mobile (Expo) — source is never part of the API image, but the manifest is
# kept so the root workspace `npm ci` (deps stage) resolves the full lockfile.
apps/mobile/*
!apps/mobile/package.json

# Web (Next.js) — deployed to Vercel separately; keep only the manifest so the
# workspace `npm ci` succeeds. The builder stage never copies the web source,
# so `turbo --filter=@vaasenk/api` only ever sees apps/api.
apps/web/*
!apps/web/package.json
