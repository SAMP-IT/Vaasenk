# Vaasenk — environment template.
#
# Copy this file to `.env` at the repo root, then fill in real values for
# your environment. Per-workspace overrides live in:
#   - apps/api/.env       runtime config for the NestJS API
#   - apps/web/.env.local public + server-side env for the Next.js web app
#   - packages/db/.env    Prisma CLI config (read by `prisma migrate/seed`)
#
# Variables are grouped by concern. Anything prefixed `NEXT_PUBLIC_` is
# inlined into the browser bundle — never put secrets there.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres + pgvector — see infrastructure/docker-compose.yml
# for the local docker equivalents)
# -----------------------------------------------------------------------------

# DATABASE_URL: pooled connection string used at runtime by @prisma/client.
# Local dev points at the docker Postgres; production points at the Supabase
# pgbouncer URL (port 6543). Server-only.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vaasenk

# DIRECT_URL: direct, non-pooled connection used by Prisma migrations.
# Required even in production — Supabase migrations cannot run through pgbouncer.
# Server-only.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vaasenk

# -----------------------------------------------------------------------------
# Supabase Auth + Storage
# Get these from the Supabase dashboard: Project Settings → API.
# -----------------------------------------------------------------------------

# SUPABASE_URL: the project's REST URL (e.g. https://abcd.supabase.co).
# Used server-side by the API for admin operations. Server-only.
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_ANON_KEY: the public anonymous JWT used by client SDKs.
# Safe to embed in browser bundles. Same value as NEXT_PUBLIC_SUPABASE_ANON_KEY.
SUPABASE_ANON_KEY=your-anon-key

# SUPABASE_SERVICE_ROLE_KEY: bypasses RLS and can perform admin operations
# (auth.admin.createUser, etc.). NEVER expose to the client. Server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Redis (BullMQ queue + cache)
# Local dev: the docker-compose redis service. Production: Railway-hosted Redis.
# Server-only.
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AI providers (used by packages/ai/ — Sprint 4+)
# Get these from each provider's dashboard. Server-only.
# -----------------------------------------------------------------------------

# OpenAI — used for text-embedding-3-small and high-volume chat completions.
OPENAI_API_KEY=sk-your-key

# Anthropic — used for Claude Sonnet on quality-sensitive completions.
ANTHROPIC_API_KEY=sk-ant-your-key

# -----------------------------------------------------------------------------
# Mobile push (Expo Push API — used by apps/api in Sprint 7.4+)
# Optional. Set only when the Expo project has "Enhanced push security" enabled.
# When set, the API attaches `Authorization: Bearer <token>` on every push send.
# Leave empty for unauthenticated calls (fine for dev + small-scale prod).
# Server-only.
# -----------------------------------------------------------------------------

# EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Web app (apps/web) — anything prefixed NEXT_PUBLIC_ is bundled into the
# browser. Treat as public.
# -----------------------------------------------------------------------------

# Public mirrors of the Supabase project URL + anon key.
# Used by @supabase/ssr in the browser client and middleware.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL the browser uses to reach the API. In production this is the
# Railway domain; in dev it's the local NestJS port.
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Optional overrides
# -----------------------------------------------------------------------------

# NODE_ENV — REQUIRED for local dev. PrismaService boots fail-soft (starts even
# when Postgres/Docker is down) ONLY when NODE_ENV=development; in every other
# value (incl. unset) it fail-hard refuses to start if the DB is unreachable.
# Production hosts (Railway/Vercel) set NODE_ENV=production themselves; leave
# this as `development` for local work and do NOT commit it as production.
NODE_ENV=development

# PORT — the API listens here. Defaults to 4000 if unset.
# PORT=4000

# CORS_ORIGINS — comma-separated list of additional allowed origins beyond
# localhost:3000 and the default *.vercel.app pattern. Server-only.
# CORS_ORIGINS=https://staging.vaasenk.com,https://vaasenk.com

# WEB_APP_URL — used by /auth/forgot-password as the password-reset redirect
# target. Defaults to http://localhost:3000.
# WEB_APP_URL=https://app.vaasenk.com
