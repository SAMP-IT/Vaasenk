# Vaasenk Mobile — environment variables.
#
# Copy to `.env.local` (or `.env`) and fill in the values. Expo loads any
# `.env` file at the project root and inlines vars prefixed with
# `EXPO_PUBLIC_` into the JS bundle at build time. Anything WITHOUT that
# prefix is server-only and NOT available at runtime in mobile code.
#
# IMPORTANT: never put secrets in EXPO_PUBLIC_ vars — they ship to the
# device and can be extracted by any user. The anon key is safe (it's
# the same key the web app uses); the service-role key NEVER goes here.

# Backend API origin. Should match NEXT_PUBLIC_API_URL on web. Use the
# LAN IP (e.g. http://192.168.1.42:4000) when testing on a physical
# device — localhost won't resolve from the phone.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Supabase project — same project as web/api, just keyed for client use.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
