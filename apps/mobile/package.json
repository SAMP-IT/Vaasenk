    "@vaasenk/ui": "*",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-file-system": "~18.0.12",
