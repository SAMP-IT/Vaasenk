{
  "name": "@vaasenk/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Vaasenk Expo mobile application (student-first + teacher flows).",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "echo \"@vaasenk/mobile build is performed via EAS Build, not turbo. Lint + typecheck cover CI smoke checks.\" && exit 0",
