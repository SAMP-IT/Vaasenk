{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "roots": ["<rootDir>/test", "<rootDir>/src"],
  "testRegex": ".unit.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      { "tsconfig": "<rootDir>/tsconfig.json", "isolatedModules": true }
    ]
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
